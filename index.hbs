{{!< default}}
<div class="gh-page">
    <div class="gh-container">

        {{!-- Hero / Intro Section --}}
        <section class="gh-hero">
            <h1 class="gh-hero-title">{{@site.title}}</h1>
            {{#if @site.description}}
                <p class="gh-hero-bio">{{@site.description}}</p>
            {{/if}}
        </section>

        {{!-- Projects Section --}}
        <section class="gh-projects">
            <h2 class="gh-projects-heading">Projects</h2>
            <ul class="gh-projects-list">
                <li class="gh-project-item">
                    <a class="gh-project-name" href="#">Project One</a>
                    <span class="gh-project-desc">A short description of what this project does and why it matters.</span>
                </li>
                <li class="gh-project-item">
                    <a class="gh-project-name" href="#">Project Two</a>
                    <span class="gh-project-desc">Another project with a concise one-line summary of its purpose.</span>
                </li>
                <li class="gh-project-item">
                    <a class="gh-project-name" href="#">Project Three</a>
                    <span class="gh-project-desc">A third project — keep descriptions short and punchy.</span>
                </li>
            </ul>
        </section>

        {{!-- Posts List --}}
        <section class="gh-postlist">
            <h2 class="gh-postlist-heading">Writing</h2>

            {{#foreach posts}}
            <article class="gh-postlist-item">
                <a class="gh-postlist-link" href="{{url}}">
                    <span class="gh-postlist-title">{{title}}</span>
                    <span class="gh-postlist-date">{{date format="MMM YYYY"}}</span>
                </a>
                {{#if excerpt}}
                    <p class="gh-postlist-excerpt">{{excerpt words="20"}}</p>
                {{/if}}
            </article>
            {{/foreach}}
        </section>

        {{!-- Pagination --}}
        <noscript>
            <div class="gh-pagination">
                {{pagination}}
            </div>
        </noscript>

    </div>
</div>
